    "ts-node-dev": "^2.0.0",
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pg": "^8.22.0",
    "redis": "^5.12.1",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.31",
    "zod": "^4.4.3"
  }
